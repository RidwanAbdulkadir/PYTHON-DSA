'''
Question: Write  a function to detect if there is a cycle in a graph using DFS traversal.
'''
def has_cycle(graph):
    visited = [False] * graph.num_nodes #this will create a list to keep track of visited nodes in the DFS traversal. The list will be initialized with False values, indicating that no nodes have been visited yet.

    def dfs(node, parent):
        visited[node] = True #this will mark the current node as visited in the visited list.

        for neighbor in graph.adj_list[node]: #this will iterate through the adjacent nodes of the current node in the adjacency list representation of the graph.
            if not visited[neighbor]: #this will check if each adjacent node has not been visited yet. If it has not been visited, we will perform a DFS traversal on that node.
                if dfs(neighbor, node): #this will perform a DFS traversal on the adjacent node. If it returns True, it means a cycle has been detected.
                    return True
            elif neighbor != parent: #this will check if the adjacent node has already been visited and is not the parent of the current node. If this condition is true, it means a cycle has been detected.
                return True

        return False #if we finish checking all adjacent nodes and do not find any cycles, we return False.

    for node in range(graph.num_nodes): #this will iterate through each node in the graph.
        if not visited[node]: #this will check if the current node has not been visited yet. If it has not been visited, we will perform a DFS traversal starting from that node to check for cycles.
            if dfs(node, -1): #this will perform a DFS traversal starting from the current node. The parent parameter is set to -1 since the starting node does not have a parent.
                return True

    return False #if we finish checking all nodes and do not find any cycles, we return False.

