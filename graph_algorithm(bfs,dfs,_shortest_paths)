'''
DfS pseudocode:

procedure DFS_iterative(G, root) is
    let S be a stack
    label root as discovered
    S.push(root)
    while S is not empty do
        v := S.pop()
        if v is the goal then
            return v
        for all edges from v to w in G.adjacentEdges(v) do
            if w is not labeled as discovered then
                label w as discovered
                S.push(w)   
'''

def dfs(graph, start):
    visited = [False] * graph.num_nodes #this will create a list to keep track of visited nodes in the DFS traversal. The list will be initialized with False values, indicating that no nodes have been visited yet.
    stack = [start] #this will create a stack to keep track of nodes to visit in the DFS traversal. The stack will be initialized with the starting node.

    while stack: #this will continue the DFS traversal until there are no more nodes to visit in the stack.
        node = stack.pop() #this will remove and return the topmost node from the stack, which is the next node to visit in the DFS traversal.

        if not visited[node]: #this will check if the current node has not been visited yet. If it has not been visited, we will mark it as visited and add its adjacent nodes to the stack for further exploration.
