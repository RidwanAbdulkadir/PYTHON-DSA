            for neighbor in graph.adj_list[node]: #this will iterate through the adjacent nodes of the current node in the adjacency list representation of the graph.
                if not visited[neighbor]: #this will check if each adjacent node has not been visited yet. If it has not been visited, we will add it to the stack for further exploration.
                    stack.append(neighbor) #this will add the adjacent node to the top of the stack for further exploration in the DFS traversal.
        
